<!DOCTYPE html>

  <head>
    <style>
      .container { width: 100%; font-family: Arial, Helvetica, sans-serif;
      margin: 0 auto; } span { display: block; } img { max-width: 100px; }
    </style>
  </head>
  <body>
    <div class="container">
      <img
        src="https://api-lmstore.s3.us-east-2.amazonaws.com/product/1c8a74efff0922052a436175c03bca76-agrvai.png"
